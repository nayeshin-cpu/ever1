{
  "framework": "nextjs",
  "regions": ["icn1"],
  "functions": {
    "src/app/api/**": {
      "maxDuration": 30
    },
    "src/app/api/generate/route.ts": {
      "maxDuration": 10
    },
    "src/app/api/upload/photo/route.ts": {
      "maxDuration": 30
    }
  },
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" }
      ]
    }
  ]
}
